{
  "name": "foundation-intelligence-engine",
  "version": "0.1.0",
  "private": true,
  "description": "Evidence-backed foundation and funder intelligence pipeline.",
  "type": "module",
  "scripts": {
    "dev": "tsx src/cli/index.ts",
    "crawl": "tsx src/cli/index.ts crawl",
    "export": "tsx src/cli/index.ts export",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit",
    "test": "tsx --test tests/**/*.test.ts",
    "lint": "eslint . --ext .ts",
    "sample": "tsx src/cli/index.ts crawl --seeds https://www.tuborgfondet.dk,https://www.tryghed.dk --max-pages 18 --out data/outputs/sample",
    "mvp": "tsx src/cli/index.ts crawl --seeds https://www.tuborgfondet.dk,https://www.tryghed.dk --max-pages 4 --out data/outputs/mvp"
  },
  "dependencies": {
    "@crawlee/cheerio": "^3.13.0",
    "cheerio": "^1.0.0",
    "dotenv": "^16.4.7",
    "got": "^14.4.5",
    "p-limit": "^6.2.0",
    "pdf-parse": "^1.1.1",
    "pg": "^8.13.1",
    "pino": "^9.5.0",
    "pino-pretty": "^11.3.0",
    "robots-parser": "^3.0.1",
    "tsx": "^4.19.2",
    "yargs": "^17.7.2",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/pdf-parse": "^1.1.4",
    "@types/pg": "^8.11.10",
    "@types/yargs": "^17.0.33",
    "eslint": "^9.17.0",
    "typescript": "^5.7.2"
  }
}
